# ====================
# Telegram Configuration
# ====================
# Hướng dẫn lấy TELEGRAM_TOKEN và TELEGRAM_CHAT_ID:
#
# 1. TELEGRAM_TOKEN:
#    - Tìm BotFather trên Telegram (@BotFather)
#    - Gửi /start và sau đó /newbot
#    - Đặt tên bot và username
#    - BotFather sẽ cấp cho bạn TOKEN
#    - Dán TOKEN dưới đây
#
# 2. TELEGRAM_CHAT_ID:
#    - Bạn có thể lấy chat ID theo 2 cách:
#    
#    Cách 1: Sử dụng bot:
#    - Tìm bot vừa tạo trên Telegram
#    - Gửi bất kỳ tin nhắn nào
#    - Truy cập: https://api.telegram.org/bot<TOKEN>/getUpdates
#    - Thay <TOKEN> bằng token thực của bạn
#    - Tìm "chat":{"id": <YOUR_CHAT_ID>} trong response
#    
#    Cách 2: Sử dụng @userinfobot:
#    - Tìm @userinfobot trên Telegram
#    - Gửi /start
#    - Bot sẽ trả về chat ID của bạn

TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ====================
# Blockchain Configuration (Tùy chọn)
# ====================
# SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your_infura_key
# SEPOLIA_CONTRACT_ADDRESS=0x97A093BB0563AC74080291b7eAFE0582638c35Ad
# SEPOLIA_PRIVATE_KEY=your_private_key_here
